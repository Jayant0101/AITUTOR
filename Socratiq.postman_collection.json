{
  "info": {
    "name": "SocratiQ AI Learning Platform",
    "description": "Complete API collection for the SocratiQ AI Learning Platform.\n\nSetup:\n1. Import this collection and the environment file into Postman.\n2. Run 'Register User' then 'Login User' — the token is saved automatically.\n3. Upload a document via 'Upload Document', then test Chat and Quiz endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"learner@example.com\",\n  \"password\": \"StrongPass123!\",\n  \"display_name\": \"Test Learner\"\n}"
            },
            "url": {"raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"]}
          }
        },
        {
          "name": "Login User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.access_token) {",
                  "    pm.environment.set('authToken', json.access_token);",
                  "    console.log('Token saved:', json.access_token.substring(0,20) + '...');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"learner@example.com\",\n  \"password\": \"StrongPass123!\"\n}"
            },
            "url": {"raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"]}
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{authToken}}"}],
            "url": {"raw": "{{baseUrl}}/auth/me", "host": ["{{baseUrl}}"], "path": ["auth", "me"]}
          }
        }
      ]
    },
    {
      "name": "Ingestion",
      "item": [
        {
          "name": "Upload Document",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.id) { pm.environment.set('fileId', json.id); }"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization", "value": "Bearer {{authToken}}"}],
            "body": {
              "mode": "formdata",
              "formdata": [{"key": "file", "type": "file", "src": "/path/to/your/sample.md"}]
            },
            "url": {"raw": "{{baseUrl}}/ingest/upload", "host": ["{{baseUrl}}"], "path": ["ingest", "upload"]}
          }
        },
        {
          "name": "Reload Knowledge Base",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{authToken}}"}
            ],
            "body": {"mode": "raw", "raw": "{}"},
            "url": {"raw": "{{baseUrl}}/ingest", "host": ["{{baseUrl}}"], "path": ["ingest"]}
          }
        },
        {
          "name": "YouTube Search",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{authToken}}"}
            ],
            "body": {"mode": "raw", "raw": "{\n  \"query\": \"BM25 information retrieval explained\"\n}"},
            "url": {"raw": "{{baseUrl}}/search/youtube", "host": ["{{baseUrl}}"], "path": ["search", "youtube"]}
          }
        }
      ]
    },
    {
      "name": "Chat",
      "item": [
        {
          "name": "Chat Query (Socratic)",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{authToken}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"What is BM25 and how does it work?\",\n  \"mode\": \"socratic\",\n  \"top_k\": 3\n}"
            },
            "url": {"raw": "{{baseUrl}}/chat/query", "host": ["{{baseUrl}}"], "path": ["chat", "query"]}
          }
        },
        {
          "name": "Chat Query (Quiz Mode)",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{authToken}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"Quiz me on knowledge graphs\",\n  \"mode\": \"quiz\",\n  \"top_k\": 3\n}"
            },
            "url": {"raw": "{{baseUrl}}/chat/query", "host": ["{{baseUrl}}"], "path": ["chat", "query"]}
          }
        },
        {
          "name": "Chat Query with Attachment",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{authToken}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"Summarise the key concepts in my document.\",\n  \"mode\": \"socratic\",\n  \"top_k\": 3,\n  \"attachments\": [{\"id\": \"{{fileId}}\"}]\n}"
            },
            "url": {"raw": "{{baseUrl}}/chat/query", "host": ["{{baseUrl}}"], "path": ["chat", "query"]}
          }
        },
        {
          "name": "Chat Stream",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{authToken}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"Explain the learner model\",\n  \"mode\": \"socratic\"\n}"
            },
            "url": {"raw": "{{baseUrl}}/chat/stream", "host": ["{{baseUrl}}"], "path": ["chat", "stream"]}
          }
        }
      ]
    },
    {
      "name": "Quiz",
      "item": [
        {
          "name": "Generate MCQ Quiz",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.quiz_id) { pm.environment.set('quizId', json.quiz_id); }",
                  "console.log('Quiz ID saved:', json.quiz_id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{authToken}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"topic\": \"BM25 Retrieval\",\n  \"difficulty\": \"medium\",\n  \"num_questions\": 5\n}"
            },
            "url": {"raw": "{{baseUrl}}/quiz/generate", "host": ["{{baseUrl}}"], "path": ["quiz", "generate"]}
          }
        },
        {
          "name": "Submit Quiz Answers",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{authToken}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"quiz_id\": {{quizId}},\n  \"answers\": [0, 1, 2, 0, 3],\n  \"time_taken\": 90\n}"
            },
            "url": {"raw": "{{baseUrl}}/quiz/submit", "host": ["{{baseUrl}}"], "path": ["quiz", "submit"]}
          }
        },
        {
          "name": "Quiz History",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{authToken}}"}],
            "url": {"raw": "{{baseUrl}}/quiz/history?limit=10", "host": ["{{baseUrl}}"], "path": ["quiz", "history"], "query": [{"key": "limit", "value": "10"}]}
          }
        }
      ]
    },
    {
      "name": "Learner",
      "item": [
        {
          "name": "Get Learner Profile (Topic Mastery)",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{authToken}}"}],
            "url": {"raw": "{{baseUrl}}/learner/profile", "host": ["{{baseUrl}}"], "path": ["learner", "profile"]}
          }
        },
        {
          "name": "Update Topic Mastery",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{authToken}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"topic\": \"BM25 Retrieval\",\n  \"mastery_score\": 80\n}"
            },
            "url": {"raw": "{{baseUrl}}/learner/update", "host": ["{{baseUrl}}"], "path": ["learner", "update"]}
          }
        },
        {
          "name": "Node-Level Progress (Legacy)",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{authToken}}"}],
            "url": {"raw": "{{baseUrl}}/learner/progress", "host": ["{{baseUrl}}"], "path": ["learner", "progress"]}
          }
        }
      ]
    },
    {
      "name": "System",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": {"raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"]}
          }
        },
        {
          "name": "API Docs",
          "request": {
            "method": "GET",
            "url": {"raw": "{{baseUrl}}/docs", "host": ["{{baseUrl}}"], "path": ["docs"]}
          }
        }
      ]
    }
  ],
  "variable": [
    {"key": "baseUrl", "value": "http://localhost:8000"},
    {"key": "authToken", "value": ""},
    {"key": "fileId", "value": ""},
    {"key": "quizId", "value": "1"}
  ]
}
