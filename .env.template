# SocratiQ Learning Assistant — Environment Variables
# Copy this file to .env and fill in the values

# LLM Configuration
LLM_PROVIDER=gemini        # Options: gemini, openai
LLM_MODEL=gemini-1.5-flash # Options: gemini-1.5-pro, gpt-4o-mini, etc.
LLM_TEMPERATURE=0.2

# API Keys — LLM
GEMINI_API_KEY=
OPENAI_API_KEY=

# API Keys — Web Search (at least one recommended for web fallback)
TAVILY_API_KEY=            # Free tier: https://tavily.com  (preferred)
ZENSERP_API_KEY=           # https://zenserp.com (secondary fallback)

# API Keys — Integrations
YOUTUBE_API_KEY=

# Security
JWT_SECRET_KEY=aitutor-dev-secret-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Paths & Storage (relative to project root)
DATA_DIR=backend/data
LEARNER_DB_PATH=backend/learner.db
UPLOAD_DIR=backend/uploads

# Network
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Retrieval tuning (optional — defaults shown)
RETRIEVAL_MIN_CONFIDENCE=0.20
GROUNDING_MIN_JACCARD=0.05
FACT_MIN_QUERY_OVERLAP=1

# ── How to start the server ──────────────────────────────────────────────
# cd <project_root>/backend
# uvicorn app.main:app --reload

