# SocratiQ Learning Assistant Environment Variables
# Copy this file to .env and fill in the values

# LLM Configuration
LLM_PROVIDER=gemini        # Options: gemini, openai
LLM_MODEL=gemini-1.5-flash # Options: gemini-1.5-pro, gpt-4o-mini, etc.
LLM_TEMPERATURE=0.2

# API Keys
GEMINI_API_KEY=
OPENAI_API_KEY=
YOUTUBE_API_KEY=

# Security
JWT_SECRET_KEY=socratiq-dev-secret-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Paths & Storage
DATA_DIR=backend/data
LEARNER_DB_PATH=backend/learner.db
UPLOAD_DIR=backend/uploads

# Network
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
