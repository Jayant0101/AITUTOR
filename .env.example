# SocratiQ AI Tutor — Environment Variables Example
# Copy this file to .env and fill in your actual values.
# Never commit your .env file.

# ─── LLM Provider ────────────────────────────────────────────────────────────
LLM_PROVIDER=gemini             # Options: gemini, openai
LLM_MODEL=gemini-1.5-flash      # gemini-1.5-pro | gpt-4o-mini | gpt-4o
LLM_TEMPERATURE=0.2

# ─── API Keys — LLM ──────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here
OPENAI_API_KEY=your-openai-api-key-here

# ─── API Keys — Web Search ────────────────────────────────────────────────────
TAVILY_API_KEY=your-tavily-api-key-here
ZENSERP_API_KEY=your-zenserp-api-key-here

# ─── API Keys — Integrations ─────────────────────────────────────────────────
YOUTUBE_API_KEY=your-youtube-data-api-key-here

# ─── Security ────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=replace-with-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── Database (Supabase) ─────────────────────────────────────────────────────
# Required only when using Supabase instead of the default SQLite learner DB.
# Format: postgresql://postgres:[PASSWORD]@[HOST]:6543/postgres
# DATABASE_URL=postgresql://postgres:password@db.xxxx.supabase.co:6543/postgres
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_KEY=your-supabase-anon-key

# ─── Paths & Storage ─────────────────────────────────────────────────────────
DATA_DIR=backend/data
LEARNER_DB_PATH=backend/learner.db
UPLOAD_DIR=backend/uploads

# ─── Network / CORS ──────────────────────────────────────────────────────────
# In production, set this to your Vercel frontend URL.
# Example: https://your-app.vercel.app
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Performance ─────────────────────────────────────────────────────────────
# Number of gunicorn worker processes (Railway / Docker).
WEB_CONCURRENCY=4

# ─── Retrieval Tuning (optional) ─────────────────────────────────────────────
RETRIEVAL_MIN_CONFIDENCE=0.20
GROUNDING_MIN_JACCARD=0.05
FACT_MIN_QUERY_OVERLAP=1

# ─── Frontend (must be set in Vercel dashboard, NOT in this .env file) ────────
# VITE_API_BASE_URL=https://your-backend.up.railway.app
